---
import '../styles/landing.css';
import I18nScript from '../components/I18nScript.astro';
import Banner from '../components/Banner.astro';
import LandingNav from '../components/LandingNav.astro';
import LandingFooter from '../components/LandingFooter.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'OpenWarp — Bring any AI model into your terminal',
  description = 'A community fork of Warp that keeps the full terminal experience and opens the AI layer.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <Analytics />
  </head>
  <body data-locale="en">
    <I18nScript />
    <Banner
      en="Early development · Unofficial fork of Warp · Not affiliated with Warp Inc."
      zh="早期开发阶段 · Warp 的非官方社区分支 · 与 Warp Inc. 无隶属关系"
      ja="初期開発段階 · Warp の非公式コミュニティフォーク · Warp Inc. とは無関係"
    />
    <LandingNav />

    <slot />

    <LandingFooter />

    <script>
      // 语言切换、页内导航、标签页、复制按钮与滚动渐显
      (function () {
        const htmlLang: Record<string, string> = { en: 'en', zh: 'zh-CN', ja: 'ja' };
        function normalizeLocale(value: string | null) {
          const tag = String(value || '').toLowerCase();
          if (tag.startsWith('zh')) return 'zh';
          if (tag.startsWith('ja')) return 'ja';
          if (tag.startsWith('en')) return 'en';
          return htmlLang[tag] ? tag : null;
        }
        function applyLocale(l: string) {
          const locale = normalizeLocale(l) || 'en';
          document.body.dataset.locale = locale;
          document.documentElement.lang = htmlLang[locale] || 'en';
          document.querySelectorAll<HTMLElement>('[data-set-lang]').forEach((option) => {
            const active = option.getAttribute('data-set-lang') === locale;
            option.classList.toggle('active', active);
            option.setAttribute('aria-selected', String(active));
          });
        }
        function closeLocaleMenus() {
          document.querySelectorAll<HTMLElement>('[data-locale-options]').forEach((menu) => {
            menu.hidden = true;
          });
          document.querySelectorAll<HTMLElement>('[data-locale-trigger]').forEach((trigger) => {
            trigger.setAttribute('aria-expanded', 'false');
          });
          document.querySelectorAll<HTMLElement>('[data-locale-menu]').forEach((menu) => {
            menu.removeAttribute('data-open');
          });
        }
        function setLocale(l: string) {
          // 仅在用户显式选择语言时持久化;自动检测应在后续访问继续跟随系统/浏览器。
          const locale = normalizeLocale(l) || 'en';
          localStorage.setItem('openwarp:locale', locale);
          applyLocale(locale);
        }
        const initialLocale = (document.body.dataset.locale as string) || 'en';
        applyLocale(initialLocale);
        document.querySelectorAll<HTMLElement>('[data-locale-menu]').forEach((menu) => {
          const trigger = menu.querySelector<HTMLButtonElement>('[data-locale-trigger]');
          const options = menu.querySelector<HTMLElement>('[data-locale-options]');
          if (!trigger || !options) return;
          trigger.addEventListener('click', (event) => {
            event.stopPropagation();
            const shouldOpen = options.hidden;
            closeLocaleMenus();
            options.hidden = !shouldOpen;
            trigger.setAttribute('aria-expanded', String(shouldOpen));
            if (shouldOpen) menu.setAttribute('data-open', 'true');
          });
          menu.querySelectorAll<HTMLButtonElement>('[data-set-lang]').forEach((option) => {
            option.addEventListener('click', (event) => {
              event.stopPropagation();
              setLocale(option.getAttribute('data-set-lang') || 'en');
              closeLocaleMenus();
            });
          });
        });
        document.addEventListener('click', (event) => {
          const target = event.target as Element | null;
          if (!target?.closest('[data-locale-menu]')) closeLocaleMenus();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeLocaleMenus();
        });

        // 顶部导航滚动阴影
        const navEl = document.querySelector('header.nav');
        function onScroll() {
          if (navEl) navEl.classList.toggle('scrolled', window.scrollY > 8);
        }
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // 移动端导航开关
        const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
        const links = document.getElementById('primary-nav');
        if (toggle && links) {
          toggle.addEventListener('click', () => {
            const open = links.classList.toggle('open');
            toggle.setAttribute('aria-expanded', String(open));
          });
          links.querySelectorAll('a').forEach((a) =>
            a.addEventListener('click', () => {
              links.classList.remove('open');
              toggle.setAttribute('aria-expanded', 'false');
            }),
          );
        }

        // 页内平滑滚动
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href')?.slice(1);
            const t = id ? document.getElementById(id) : null;
            if (!t) return;
            e.preventDefault();
            window.scrollTo({ top: t.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
          });
        });

        // 服务商标签页与动画轨道
        document.querySelectorAll<HTMLElement>('.prov-tabs').forEach((tabs) => {
          const rail = tabs.querySelector<HTMLElement>('[data-prov-rail]');
          const moveRail = (b: HTMLButtonElement) => {
            if (!rail) return;
            const r = b.getBoundingClientRect();
            const t = tabs.getBoundingClientRect();
            rail.style.width = `${r.width}px`;
            rail.style.transform = `translateX(${r.left - t.left - 4}px)`;
          };
          const buttons = tabs.querySelectorAll<HTMLButtonElement>('button');
          const initial = tabs.querySelector<HTMLButtonElement>('button.active') ?? buttons[0];
          if (initial) requestAnimationFrame(() => moveRail(initial));
          window.addEventListener('resize', () => {
            const a = tabs.querySelector<HTMLButtonElement>('button.active');
            if (a) moveRail(a);
          });
          buttons.forEach((b) => {
            b.addEventListener('click', () => {
              const name = b.getAttribute('data-pf');
              buttons.forEach((x) => x.classList.toggle('active', x === b));
              moveRail(b);
              document.querySelectorAll<HTMLElement>('[data-pf-pane]').forEach((p) => {
                p.hidden = p.getAttribute('data-pf-pane') !== name;
              });
            });
          });
        });

        // 安装方式标签页
        document.querySelectorAll<HTMLElement>('.install-tabs').forEach((tabs) => {
          tabs.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
            b.addEventListener('click', () => {
              const name = b.getAttribute('data-tab');
              tabs.querySelectorAll('button').forEach((x) => x.classList.toggle('active', x === b));
              const card = tabs.parentElement;
              card?.querySelectorAll<HTMLElement>('[data-pane]').forEach((p) => {
                p.hidden = p.getAttribute('data-pane') !== name;
              });
            });
          });
        });

        // 复制按钮
        document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const pre = btn.closest('.pre-wrap, .code-card')?.querySelector<HTMLElement>('pre.code');
            if (pre && navigator.clipboard) navigator.clipboard.writeText(pre.innerText);
            const prev = btn.textContent;
            btn.textContent = document.body.dataset.locale === 'zh' ? '已复制' : document.body.dataset.locale === 'ja' ? 'コピー済み' : 'Copied';
            btn.classList.add('copied');
            setTimeout(() => {
              btn.textContent = prev;
              btn.classList.remove('copied');
            }, 1400);
          });
        });

        // 滚动渐显
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
        );
        document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
