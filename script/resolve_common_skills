#!/usr/bin/env bash

set -eo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"
COMMON_SKILLS_REPO="warpdotdev/common-skills"
COMMON_SKILLS_REF="${WARP_COMMON_SKILLS_REF:-main}"
RAW_BASE_URL="${WARP_COMMON_SKILLS_RAW_BASE_URL:-https://raw.githubusercontent.com/${COMMON_SKILLS_REPO}/${COMMON_SKILLS_REF}/scripts}"
SCRIPT_NAME=""

usage() {
  cat <<EOF
Usage: ./script/resolve_common_skills <script-name> [-- <script-args...>]

Execute a script from warpdotdev/common-skills/scripts.

Resolution order:
  1. WARP_COMMON_SKILLS_SCRIPTS_DIR
  2. A sibling ../common-skills checkout
  3. Any worktree belonging to that sibling checkout
  4. The raw script from ${COMMON_SKILLS_REPO}

Environment:
  WARP_COMMON_SKILLS_SCRIPTS_DIR=/path/to/common-skills/scripts
      Override where common-skills management scripts are loaded from.
  WARP_COMMON_SKILLS_FORCE_REMOTE=1
      Skip local script lookup and execute the raw remote script.
  WARP_COMMON_SKILLS_REF=<git-ref>
      Override the remote common-skills ref used for raw script fallback.
  WARP_COMMON_SKILLS_RAW_BASE_URL=https://...
      Override the remote base URL used for raw script fallback.
EOF
}

execute_from_dir() {
  local scripts_dir="$1"
  local script_path="${scripts_dir}/${SCRIPT_NAME}"
  shift

  if [[ -x "${script_path}" ]]; then
    exec "${script_path}" "$@"
  fi

  if [[ -f "${script_path}" ]]; then
    exec bash "${script_path}" "$@"
  fi

  return 1
}

execute_from_sibling_checkout() {
  local candidate_dir=""
  local common_skills_checkout="${REPO_ROOT}/../common-skills"
  local line=""

  candidate_dir="${common_skills_checkout}/scripts"
  if execute_from_dir "${candidate_dir}" "$@"; then
    return 0
  fi

  if [[ -d "${common_skills_checkout}/.git" || -f "${common_skills_checkout}/.git" ]]; then
    while IFS= read -r line; do
      case "${line}" in
        worktree\ *)
          candidate_dir="${line#worktree }/scripts"
          if execute_from_dir "${candidate_dir}" "$@"; then
            return 0
          fi
          ;;
      esac
    done < <(git -C "${common_skills_checkout}" worktree list --porcelain 2>/dev/null)
  fi

  return 1
}

execute_from_remote() {
  local raw_url="${RAW_BASE_URL%/}/${SCRIPT_NAME}"

  if ! command -v curl >/dev/null 2>&1; then
    echo "error: curl is required to fetch ${raw_url}" >&2
    return 1
  fi

  curl -fsSL "${raw_url}" | bash -s -- "$@"
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
  */*|.|..|"")
    echo "error: invalid common-skills script name: $1" >&2
    usage >&2
    exit 1
    ;;
  *)
    SCRIPT_NAME="$1"
    case "${SCRIPT_NAME}" in
      *[!A-Za-z0-9_-]*)
        echo "error: invalid common-skills script name: ${SCRIPT_NAME}" >&2
        usage >&2
        exit 1
        ;;
    esac
    shift
    ;;
esac
if [[ "${1:-}" = "--" ]]; then
  shift
fi

if [[ "${WARP_COMMON_SKILLS_FORCE_REMOTE:-}" != "1" ]]; then
  if [[ -n "${WARP_COMMON_SKILLS_SCRIPTS_DIR:-}" ]] && execute_from_dir "${WARP_COMMON_SKILLS_SCRIPTS_DIR}" "$@"; then
    exit 0
  fi

  if execute_from_sibling_checkout "$@"; then
    exit 0
  fi
fi

execute_from_remote "$@"
