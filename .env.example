# Local-AI bypass for the warpdotdev/warp fork.
#
# Loaded by `dotenvy::from_filename(".env")` at the very top of `run()` in app/src/lib.rs.
# Copy to `.env` (gitignored) and uncomment the lines you want active.

# Boot straight into a logged-in fake-user state. Skips the browser-check / paywall modal.
# This is the recommended way to run the local-model fork. The model-selector menu will
# show the local model list (Claude, GPT-5.5 variants, Ollama) and route to the matching
# CLI or HTTP endpoint.
# Implied (auto-on) whenever WARP_LOCAL_AI is set.
# WARP_BYPASS_AUTH=1

# Legacy provider override (backwards compat). When set, overrides the default model
# selection to the matching provider. The full model list still appears in the menu.
# One of: claude | codex | ollama
# WARP_LOCAL_AI=claude

# --- Ollama settings ---
# Used when WARP_LOCAL_AI=ollama or an Ollama model is selected from the menu.

# Ollama daemon URL (defaults to http://localhost:11434 if not set).
# OLLAMA_HOST=http://localhost:11434

# Model to use for the "Ollama (custom)" menu entry and for WARP_LOCAL_AI=ollama
# when no specific model is selected from the menu (defaults to "llama3.2").
# OLLAMA_MODEL=qwen2.5-coder:7b

# --- jCodeMunch local codebase index ---
# When WARP_BYPASS_AUTH=1 is active and jcodemunch-mcp (or uvx) is on PATH,
# Warp auto-registers jCodeMunch as a local MCP server in the Warp home config
# (~/.warp-oss/.mcp.json on OSS builds). The agent can then call tools like
# get_symbol, search_symbols, and get_file_outline to read specific functions
# instead of whole files - reducing context usage significantly.
#
# Prerequisite: pip install jcodemunch-mcp   OR   brew install uv (uses uvx)
# Set to 1 to disable auto-registration if you manage the MCP config yourself.
# JCODEMUNCH_DISABLED=0

# --- Provider credentials (not stored in code) ---

# OpenRouter API key (required for OpenRouter models, planned for a future PR).
# OPENROUTER_API_KEY=sk-or-...
